    <content type="html">&lt;p&gt;初步设置项目。&lt;/p&gt;
&lt;p&gt;支持 &lt;code class="docutils literal notranslate"&gt;&lt;span class="pre"&gt;{fa}`check,text-success&lt;/span&gt; &lt;span class="pre"&gt;mr-1`&lt;/span&gt;&lt;/code&gt; 渲染：&lt;span class="fa fa-check text-success mr-1"&gt;&lt;/span&gt;。&lt;/p&gt;

    &lt;script type="text/x-thebe-config"&gt;
    {
        requestKernel: true,
        binderOptions: {
            repo: "daobook/daobook.github.io",
            ref: "main",
        },
        codeMirrorConfig: {
            theme: "abcdef",
            mode: "python"
        },
        kernelOptions: {
            kernelName: "python3",
            path: "./."
        },
        predefinedOutput: true
    }
    &lt;/script&gt;
    &lt;script&gt;kernelName = 'python3'&lt;/script&gt;</content>
